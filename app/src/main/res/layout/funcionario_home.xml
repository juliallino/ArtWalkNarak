<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <LinearLayout
        android:id="@+id/layouttitulo"
        android:layout_width="match_parent"
        android:layout_height="91dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="120dp"
            android:src="@drawable/logoinicio"></ImageView>

        <TextView
            android:id="@+id/titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:background="@color/azulclaro"

            android:paddingLeft="55dp"
            android:paddingTop="10dp"
            android:paddingRight="20dp"
            android:paddingBottom="6.5dp"

            android:hint="Espaço Cultural Unifor"
            android:textColorHint="@color/azulescuro"
            android:textSize="20dp"
            android:textStyle="bold"

            ></TextView>

    </LinearLayout>

    <SearchView
        android:id="@+id/busca"
        android:layout_width="wrap_content"
        android:layout_height="45dp"
        android:layout_below="@id/layouttitulo"
        android:layout_marginLeft="240dp"
        android:layout_marginTop="17dp"
        android:layout_marginRight="10dp"
        android:background="@drawable/busca_background"
        android:backgroundTint="@color/azulclaro"
        android:iconifiedByDefault="false"
        android:queryBackground="@color/transparente"
        android:queryHint="busca..."></SearchView>

    <TextView
        android:id="@+id/subtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_below="@id/busca"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"

        android:text="Exposições do Acervo"
        android:textColor="@color/azulescuro"
        android:textSize="18dp"
        android:textStyle="bold"

        ></TextView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerviewExposicoesFuncionarios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/subtitulo"
        android:layout_marginTop="1dp"
        tools:itemCount="2"
        tools:listitem="@layout/funcionario_list_exposicoes_home_view"></androidx.recyclerview.widget.RecyclerView>


    <ImageButton
        android:id="@+id/botaoaddexpo"
        android:layout_width="309dp"
        android:layout_height="95dp"
        android:layout_below="@id/recyclerviewExposicoesFuncionarios"
        android:layout_marginLeft="50dp"
        android:layout_marginTop="6dp"
        android:contentDescription="Botão para ajustar add uma nova exposição"
        android:src="@drawable/botaoadd"></ImageButton>

    <Button
        android:id="@+id/botaoSair"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/botaoaddexpo"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="18dp"
        android:layout_marginRight="20dp"
        android:backgroundTint="@color/azulclaro"
        android:text="logout"
        android:textColor="@color/azulescuro"
        android:textStyle="bold"></Button>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="2dp"
        android:background="@color/azulclaro"
        android:padding="10dp"></com.google.android.material.navigation.NavigationView>


</RelativeLayout>