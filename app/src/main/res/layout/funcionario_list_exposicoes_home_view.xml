<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:layout_margin="20dp">

    <RelativeLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="5dp">
    <TextView
        android:id="@+id/nomeExposicao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:text="Nome da Exposição"
        android:textColor="@color/azulmedio"
        android:textSize="16dp"
        android:textStyle="bold"></TextView>

    <ImageButton
        android:id="@+id/imagemExposicao"
        android:layout_width="285dp"
        android:layout_height="100dp"
        android:layout_below="@id/nomeExposicao"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="10dp"
        android:contentDescription="Botão da imagem"
        android:src="@drawable/centelhas"
        android:background="@color/azulclaro"
        android:scaleType="fitXY"
        android:backgroundTint="@color/azulclaro"
        ></ImageButton>

    <ImageButton
        android:id="@+id/editExposicao"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignTop="@id/imagemExposicao"
        android:layout_marginLeft="15dp"
        android:layout_toEndOf="@id/imagemExposicao"
        android:backgroundTint="#00FFFFFF"
        android:contentDescription="Botão para editar a exposição"
        android:src="@drawable/baseline_edit_24"
        ></ImageButton>

    <ImageButton
        android:id="@+id/deleteExposicao"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignBottom="@id/imagemExposicao"
        android:layout_marginLeft="15dp"
        android:layout_toEndOf="@id/imagemExposicao"
        android:backgroundTint="#00FFFFFF"
        android:contentDescription="Botão para deletar a exposição"
        android:src="@drawable/baseline_delete_forever_24"
        ></ImageButton>
</RelativeLayout>
</androidx.cardview.widget.CardView>